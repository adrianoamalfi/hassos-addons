#!/usr/bin/env bashio

# Ensure user extensions folder exists
mkdir -p /data/duplicati/scripts

cd /data/duplicati || exit

# Wait for the pre-auth token generated by start_nginx (shared via file)
bashio::log.info "Waiting for nginx pre-auth token..."
for i in $(seq 1 30); do
    if [ -f /tmp/pre_auth_token ]; then
        break
    fi
    sleep 1
done

if [ ! -f /tmp/pre_auth_token ]; then
    bashio::log.error "Pre-auth token not found after 30s, starting without it"
else
    PRE_AUTH_TOKEN="$(cat /tmp/pre_auth_token)"
    export DUPLICATI__WEBSERVICE_PRE_AUTH_TOKENS="${PRE_AUTH_TOKEN}"
    bashio::log.info "Pre-auth token loaded"
fi

# Read log level from addon options (fallback when Supervisor API is unavailable, e.g. in CI)
LOG_LEVEL="information"
if bashio::config.exists 'log_level' 2>/dev/null; then
    LOG_LEVEL=$(bashio::config 'log_level')
fi
bashio::log.info "Duplicati log level: ${LOG_LEVEL}"

# Duplicati listens on internal port 8200 (nginx on 8080 handles ingress)
bashio::log.info "Starting Duplicati on internal port 8200..."

exec duplicati-server \
    --webservice-interface=any --webservice-port=8200 \
    --server-datafolder="/data/duplicati" \
    --webservice-allowed-hostnames=* \
    --webservice-disable-signin-tokens \
    --webservice-disable-https \
    --disable-db-encryption \
    --log-level="${LOG_LEVEL}"
