#!/usr/bin/env bashio

SECRETS_FILE="/data/secrets.json"
TOKEN_FILE="/tmp/pre_auth_token"
NGINX_CONF="/tmp/nginx.conf"
JS_SHIM="/tmp/ingress-fix.js"

# Read addon options
DEFAULT_UI=$(bashio::config 'default_ui' 'ngclient')
bashio::log.info "Default UI: ${DEFAULT_UI}"

# ============================================================
# 1. Generate or load the pre-auth token (persisted across restarts)
# ============================================================
PRE_AUTH_TOKEN=""
if [ -f "$SECRETS_FILE" ]; then
    PRE_AUTH_TOKEN="$(jq -r '.pre_auth_token // empty' "$SECRETS_FILE" 2>/dev/null)"
fi

if [ -z "$PRE_AUTH_TOKEN" ] || [ "${#PRE_AUTH_TOKEN}" -lt 10 ]; then
    PRE_AUTH_TOKEN="$(head -c 256 /dev/urandom | tr -dc 'a-zA-Z0-9' | head -c 32)"
    echo "{\"pre_auth_token\": \"${PRE_AUTH_TOKEN}\"}" > "$SECRETS_FILE"
    bashio::log.info "Generated new pre-auth token"
else
    bashio::log.info "Loaded existing pre-auth token"
fi

# Share token with start_duplicati via file
echo -n "$PRE_AUTH_TOKEN" > "$TOKEN_FILE"

# ============================================================
# 2. Generate the JavaScript ingress shim
# ============================================================
cat > "$JS_SHIM" << 'JSEOF'
(function() {
    var m = window.location.pathname.match(/^(\/api\/hassio_ingress\/[^\/]+)/);
    if (!m) return;
    var prefix = m[1];

    // Patch <base href> elements via MutationObserver
    new MutationObserver(function(mutations) {
        mutations.forEach(function(mutation) {
            mutation.addedNodes.forEach(function(node) {
                if (node.tagName === 'BASE') {
                    var href = node.getAttribute('href');
                    if (href && !href.startsWith(prefix)) {
                        node.setAttribute('href', prefix + href);
                    }
                }
            });
        });
    }).observe(document.documentElement, { childList: true, subtree: true });

    // Also fix any existing <base> elements
    document.querySelectorAll('base[href]').forEach(function(base) {
        var href = base.getAttribute('href');
        if (href && !href.startsWith(prefix)) {
            base.setAttribute('href', prefix + href);
        }
    });

    // Patch fetch() to prefix absolute URLs (skip if already prefixed)
    var origFetch = window.fetch;
    window.fetch = function(input, init) {
        if (typeof input === 'string' && input.startsWith('/') && !input.startsWith(prefix)) {
            input = prefix + input;
        } else if (input instanceof Request) {
            var url = input.url;
            var origin = window.location.origin;
            if (url.startsWith(origin + '/') && !url.startsWith(origin + prefix)) {
                input = new Request(origin + prefix + url.substring(origin.length), input);
            }
        }
        return origFetch.call(this, input, init);
    };

    // Patch XMLHttpRequest.open() to prefix absolute URLs
    var origOpen = XMLHttpRequest.prototype.open;
    XMLHttpRequest.prototype.open = function(method, url) {
        if (typeof url === 'string' && url.startsWith('/') && !url.startsWith(prefix)) {
            url = prefix + url;
        }
        var args = Array.prototype.slice.call(arguments);
        args[1] = url;
        return origOpen.apply(this, args);
    };

    // Patch WebSocket to prefix the pathname
    var OrigWebSocket = window.WebSocket;
    function PatchedWebSocket(url, protocols) {
        if (typeof url === 'string') {
            try {
                var parsed = new URL(url, window.location.origin);
                if (!parsed.pathname.startsWith(prefix)) {
                    parsed.pathname = prefix + parsed.pathname;
                }
                url = parsed.toString();
            } catch (e) { /* ignore parse errors */ }
        }
        if (protocols !== undefined) {
            return new OrigWebSocket(url, protocols);
        }
        return new OrigWebSocket(url);
    }
    PatchedWebSocket.prototype = OrigWebSocket.prototype;
    PatchedWebSocket.CONNECTING = OrigWebSocket.CONNECTING;
    PatchedWebSocket.OPEN = OrigWebSocket.OPEN;
    PatchedWebSocket.CLOSING = OrigWebSocket.CLOSING;
    PatchedWebSocket.CLOSED = OrigWebSocket.CLOSED;
    window.WebSocket = PatchedWebSocket;
})();
JSEOF

bashio::log.info "Generated ingress JavaScript shim"

# ============================================================
# 3. Generate the nginx configuration
# ============================================================
mkdir -p /tmp/nginx/body /tmp/nginx/proxy /tmp/nginx/fastcgi /tmp/nginx/uwsgi /tmp/nginx/scgi

cat > "$NGINX_CONF" << NGINXEOF
user root;
daemon off;
worker_processes 1;
error_log /dev/stderr warn;
pid /tmp/nginx.pid;

events {
    worker_connections 128;
}

http {
    access_log off;
    sendfile on;
    client_max_body_size 0;

    # Use /tmp for all temp paths (writable in container)
    client_body_temp_path /tmp/nginx/body;
    proxy_temp_path /tmp/nginx/proxy;
    fastcgi_temp_path /tmp/nginx/fastcgi;
    uwsgi_temp_path /tmp/nginx/uwsgi;
    scgi_temp_path /tmp/nginx/scgi;

    map \$http_upgrade \$connection_upgrade {
        default upgrade;
        ''      close;
    }

    server {
        listen 8080;

        # Prevent nginx from adding host:port to redirect URLs
        # (critical for HA ingress — browser must stay on HA port, not container port)
        absolute_redirect off;

        # Root redirect to Duplicati UI with ingress prefix
        location = / {
            return 307 \$http_x_ingress_path/${DEFAULT_UI}/index.html;
        }

        # Serve the ingress JavaScript shim
        location ~ ingress-fix\.js\$ {
            alias /tmp/ingress-fix.js;
            default_type application/javascript;
            add_header Cache-Control "no-cache";
        }

        # Reverse proxy to Duplicati
        location / {
            proxy_pass http://127.0.0.1:8200;

            # Pass through headers
            proxy_set_header Host \$host;
            proxy_set_header X-Real-IP \$remote_addr;
            proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto \$scheme;

            # Tell Duplicati the ingress prefix (enables new UI proxy-config meta tag)
            proxy_set_header X-Forwarded-Prefix \$http_x_ingress_path;

            # Allow iframe hosting (HA ingress uses iframes)
            proxy_set_header X-Allow-Iframe-Hosting "true";

            # Inject pre-auth token for Duplicati authentication bypass
            proxy_set_header Authorization "PreAuth ${PRE_AUTH_TOKEN}";

            # WebSocket support
            proxy_http_version 1.1;
            proxy_set_header Upgrade \$http_upgrade;
            proxy_set_header Connection \$connection_upgrade;

            # Timeouts for long-running backup operations
            proxy_read_timeout 3600s;
            proxy_send_timeout 3600s;

            # Disable upstream gzip so sub_filter can modify HTML
            proxy_set_header Accept-Encoding "";

            # Inject JavaScript shim into HTML responses
            sub_filter '</head>' '<script src="ingress-fix.js"></script></head>';
            sub_filter_once on;
        }
    }
}
NGINXEOF

bashio::log.info "Generated nginx configuration"

# ============================================================
# 4. Start nginx
# ============================================================
bashio::log.info "Starting nginx on ingress port 8080..."
exec nginx -c "$NGINX_CONF"
